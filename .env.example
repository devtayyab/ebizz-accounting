# ---------------------------------------------------------------------------
# Ebizz Accounting — environment template. Copy to `.env` and fill in.
# For local dev, run `pnpm db:start` and Supabase CLI prints these values.
# ---------------------------------------------------------------------------

# --- Supabase ---
# Project API URL (local default shown; use your cloud project URL in prod)
SUPABASE_URL=http://127.0.0.1:54321
# Public anon key — safe to expose to the browser (RLS enforces access)
SUPABASE_ANON_KEY=replace-with-local-or-cloud-anon-key
# Service role key — SERVER ONLY, never ship to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# JWT secret used to verify access tokens (from `supabase status`)
SUPABASE_JWT_SECRET=replace-with-jwt-secret

# --- API (NestJS) ---
API_PORT=3000
API_GLOBAL_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173

# --- Web (Vite) — must be prefixed VITE_ to reach the browser ---
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-or-cloud-anon-key
VITE_API_URL=http://localhost:3000/api/v1
